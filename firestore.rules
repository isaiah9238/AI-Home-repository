rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isCreatingOwnedDoc() {
      return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    // --- 1. THE BLACK BOX (Sovereign Vault) ---
    match /sovereign_vault/{vaultId} {
      allow read, write: if isOwner(vaultId);
    }

    // --- 2. THE LIBRARIAN (Workspaces, Projects & VFS) ---
    match /workspaces/{workspaceId} {
      allow read, update, delete: if isDocOwner();
      allow create: if isCreatingOwnedDoc();
    }

    match /projects/{projectId} {
      allow read, update, delete: if isDocOwner();
      allow create: if isCreatingOwnedDoc();
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
    }

    // --- 3. LOOPS, CURRICULUM & COMMENTS (Hardened) ---
    match /loops/{loopId} {
      // Must be owner or signed-in depending on system access
      allow read, update, delete: if isDocOwner();
      allow create: if isCreatingOwnedDoc();
      
      match /lines/{lineId} {
        allow read, write: if isSignedIn();
      }
    }

    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if false; 
    }

    match /derivatives/{derivativeId} {
      allow create: if isSignedIn() && request.resource.size < 5 * 1024;
      allow read, update, delete: if false;
    }

    // --- 4. INTERNAL & ADMIN ---
    match /internal_comms/{auditId} {
      allow read, write: if isSignedIn();
    }

    // Lock down primary_user path to match the authenticated UID
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}