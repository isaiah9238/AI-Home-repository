rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() {
      return request.auth != null;
    }

    // App Assets: Publicly readable icons/wallpapers, only you can upload
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // The Vault: Private user folders (e.g., /vault/ISAIAH_ID/...)
    match /vault/{userId}/{allPaths=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Safety Catch: Lock everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}