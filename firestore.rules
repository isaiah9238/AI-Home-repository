rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 1. THE BLACK BOX (Sovereign Vault) ---
    // Documents here MUST be named exactly your Firebase UID
    match /sovereign_vault/{vaultId} {
      allow read, write: if isOwner(vaultId);
    }

    // --- 2. THE LIBRARIAN (Workspaces & Projects) ---
    match /workspaces/{workspaceId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /projects/{projectId} {
      allow read, write: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
    }

    // --- 3. EXISTING FEATURES (Loops & Comments) ---
    match /loops/{loopId} {
      allow read: if true;
      allow write: if isSignedIn();
      
      match /lines/{lineId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    match /comments/{commentId} {
      allow get, list, create: if true;
      allow update, delete: if false; 
    }

    match /derivatives/{derivativeId} {
      allow create: if request.resource.size < 5 * 1024;
      allow read, update, delete: if false;
    }

    // --- 4. INTERNAL & ADMIN ---
    match /internal_comms/{auditId} {
      allow read, write: if isSignedIn();
    }

    match /users/primary_user {
      // Warning: 'if true' allows anyone in the world to edit this. 
      // Changed to 'isSignedIn()' for safety.
      allow read, write: if isSignedIn();
    }
  }
}